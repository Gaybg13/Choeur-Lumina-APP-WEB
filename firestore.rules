rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && myRole() == 'admin';
    }

    function isStaff() {
      return signedIn() && myRole() in ['admin', 'contributeur'];
    }

    match /userRoles/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    match /members/{memberId} {
      allow read: if signedIn();
      allow update: if signedIn()
        && resource.data.claimed == false
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.claimed == true;
      allow update: if signedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if isAdmin();
    }

    match /songs/{songId} {
      allow read: if signedIn();
      allow create, update, delete: if isStaff();
    }

    match /folders/{folderId} {
      allow read: if signedIn();
      allow create, update, delete: if isStaff();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create, delete: if isStaff();
      allow update: if signedIn();
    }

    match /groupChat/{messageId} {
      allow read, create: if signedIn();

      // Auteur : modification/suppression logique de son propre message.
      // Membres connectés : lecture, réactions et suppression locale.
      allow update: if signedIn() && (
        resource.data.authorUid == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['readBy', 'hiddenFor', 'reactions'])
      );
      allow delete: if false;
    }

    match /groupTyping/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /userStatus/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /conversations/{conversationId} {
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow update: if signedIn() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        function isParticipant() {
          return signedIn() && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        }

        allow read, create: if isParticipant();

        // Auteur : modification/suppression logique.
        // Participants : accusés de livraison/lecture, réactions, suppression locale.
        allow update: if isParticipant() && (
          resource.data.authorUid == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['readBy', 'deliveredBy', 'hiddenFor', 'reactions'])
        );
        allow delete: if false;
      }

      match /typing/{uid} {
        allow read: if signedIn() && request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create, update, delete: if signedIn()
          && request.auth.uid == uid
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }
  }
}
